ROOTSTOCK_TESTNET_RPC_URL=https://public-node.testnet.rsk.co
CONTRACT_ADDRESS=0xYourDeployedContractAddress
CHAIN_ID=31
PORT=3000

# Required for backend to deduct per request (must be contract owner key).
OWNER_PRIVATE_KEY=0xYourContractOwnerPrivateKey

# Used by local examples/test-client.js to sign requests as wallet owner.
SIGNER_PRIVATE_KEY=0xYourClientWalletPrivateKey
